# Copy to .env and fill in ONE provider key (or none — the pipeline runs in
# deterministic OFFLINE mode if no key is set). The provider is auto-detected
# from whichever key is present, in the order Anthropic, OpenAI, Gemini.

# --- Pick a provider by setting its key ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=        # or GEMINI_API_KEY

# --- Optional overrides ---
# Pin a provider explicitly instead of auto-detecting:
#   AGENTIC_EVAL_PROVIDER=openai
AGENTIC_EVAL_PROVIDER=

# Override the default model / judge model (otherwise each provider's default
# is used: claude-opus-4-8, gpt-4.1, gemini-2.5-pro).
AGENTIC_EVAL_MODEL=
AGENTIC_EVAL_JUDGE_MODEL=
AGENTIC_EVAL_EFFORT=high

# Where the REST API / db CLI read results from:
AGENTIC_EVAL_DB=eval_results.db
